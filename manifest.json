{
    "manifest_version": 2,
    "name": "Lichess Hide Solve Count",
    "version": "1.0",
    "description": "Ukrywa informację o liczbie rozwiązań w zadaniach Lichess",
    "permissions": ["*://lichess.org/*"],
    "content_scripts": [
      {
        "matches": ["*://lichess.org/*"],
        "js": ["content.js"],
        "run_at": "document_idle"
      }
    ]
  }